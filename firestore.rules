rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.role in ['super_admin', 'admin', 'dispatcher', 'agent'];
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.role == 'super_admin';
    }

    function isStoreUser() {
      return isAuthenticated() &&
        request.auth.token.role in ['store_owner', 'store_manager'];
    }

    function isStoreOwnerOf(storeId) {
      return isAuthenticated() && (
        request.auth.token.role in ['store_owner', 'store_manager'] &&
        (request.auth.token.storeId == storeId || request.auth.uid == storeId)
      );
    }

    // ── Stores ──────────────────────────────────────────────────────
    match /stores/{storeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isStoreOwnerOf(storeId);
    }

    // ── Produits ────────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isStoreUser();
    }

    // ── Commandes ───────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isStoreUser();
    }

    // ── Utilisateurs app ────────────────────────────────────────────
    match /app_users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // ── Catégories ──────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Commerce types ──────────────────────────────────────────────
    match /commerce_types/{typeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Zones ───────────────────────────────────────────────────────
    match /zones/{zoneId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Transactions ────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isStoreUser();
    }

    // ── Drivers ─────────────────────────────────────────────────────
    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() ||
        (isAuthenticated() && request.auth.uid == driverId);
    }

    // ── Clients ─────────────────────────────────────────────────────
    match /clients/{clientId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && request.auth.uid == clientId);
      allow write: if isAdmin() ||
        (isAuthenticated() && request.auth.uid == clientId);
    }

    // ── Notifications ───────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Tout le reste ───────────────────────────────────────────────
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
